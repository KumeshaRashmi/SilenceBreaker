# Copy this file to .env and fill in ONE provider key.
# Free option: create a Groq key at https://console.groq.com  (no card required)

GROQ_API_KEY=
# OPENAI_API_KEY=
# TOGETHER_API_KEY=

# Endpoint + model (defaults shown are for Groq)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# If you leave all keys blank, the system runs in OFFLINE mode (deterministic
# rule-based category + template responses) so it still works end-to-end.